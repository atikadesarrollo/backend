# Configuración de conexión a la base de datos
# Copia este archivo a .env y configura tus valores

# Servidor de base de datos
DATALAKE_SERVER=DATALAKE

# Nombre de la base de datos
DATALAKE_DATABASE=DATALAKE

# Credenciales SQL Server
DATALAKE_USERNAME=sa
DATALAKE_PASSWORD=jsexkodV2W4XJpI

# Tipo de autenticación: true para SQL Server, false para Windows
DATALAKE_USE_SQL_AUTH=true

# Variables de Odoo (si las necesitas en el ETL)
ODOO_URL=http://your-odoo-server:8069
ODOO_DB=your_database
ODOO_USERNAME=your_username
ODOO_PASSWORD=your_password
